{
  "//": "Workspace composer manifest for the Mine->Verify->Cover PHP adapter. The workspace is a",
  "//2": "self-contained copy of ONE target slice (cpp workspace-copy isolation pattern) — the consuming",
  "//3": "repo is never touched. require-dev pins the toolchain; require carries the slice's NARROW deps.",
  "//4": "infection/infection is PINNED to the PROBED minor line (0.34.0, composer.lock-confirmed) — NOT '*'.",
  "//5": "The translation seam (the Infection json -> Stryker-schema status map) was authored against the",
  "//6": "OBSERVED 0.34.0 json shape (see the mine-verify-cover-php SKILL.md). The pin, the observed status",
  "//7": "map, and the runner's status map move TOGETHER: bumping this pin to a new minor/major requires",
  "//8": "re-running the toolchain probe and reconciling all three before the pin is allowed to float forward.",
  "require": {
    "__PER_TARGET_DEPS__": "SLOT: the slice's real runtime deps, e.g. \"nesbot/carbon\": \"^3\". Remove this key and add the actual deps per target."
  },
  "require-dev": {
    "phpunit/phpunit": "^12",
    "infection/infection": "^0.34",
    "giorgiosironi/eris": "^1.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    }
  }
}
