{
  "//": "Workspace composer manifest for the Mine->Verify->Cover PHP adapter. The workspace is a",
  "//2": "self-contained copy of ONE target slice (cpp workspace-copy isolation pattern) — the consuming",
  "//3": "repo is never touched. require-dev pins the toolchain; require carries the slice's NARROW deps.",
  "//4": "infection/infection is PINNED to the Step-1 PROBED minor line (0.34.0, composer.lock-confirmed) —",
  "//5": "NOT '*'. The translation seam (INFECTION_STATUS_MAP in cover-php.workflow.js) was authored against",
  "//6": "the OBSERVED 0.34.0 json shape (delivery/probe-report.md). The pin, probe-report.md's observed",
  "//7": "status map, and INFECTION_STATUS_MAP move TOGETHER: bumping this pin to a new minor/major requires",
  "//8": "re-running the Step-1 probe and reconciling all three before the pin is allowed to float forward.",
  "require": {
    "__PER_TARGET_DEPS__": "SLOT: the slice's real runtime deps, e.g. \"nesbot/carbon\": \"^3\". Remove this key and add the actual deps per target."
  },
  "require-dev": {
    "phpunit/phpunit": "^12",
    "infection/infection": "^0.34",
    "giorgiosironi/eris": "^1.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    }
  }
}
